{
  "$schema": "https://opencode.ai/config.json",
  "model": "deepseek/deepseek-reasoner",
  "provider": {
    "deepseek": {
      "options": {
        "temperature": 0.7,
        "timeout": 600000
      }
    }
  },
  "instructions": [
    "CLAUDE.md"
  ],
  "watcher": {
    "ignore": [
      "node_modules/**",
      "vendor/**",
      "_site/**",
      ".jekyll-cache/**",
      ".bundle/**"
    ]
  },
  "formatter": {
    "prettier": {
      "disabled": true
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "write": "allow"
  },
  "snapshot": true,
  "autoupdate": false
}